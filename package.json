{
  "name": "ytreup",
  "version": "1.0.0",
  "description": "YouTube Re-upload Manager",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron ."
  },
  "dependencies": {
    "axios": "^1.6.0",
    "googleapis": "^140.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ytreup.app",
    "productName": "YTReUp",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*"],
    "extraResources": [{ "from": "bin/", "to": "bin/", "filter": ["**/*"] }],
    "linux": { "target": "AppImage" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" }
  }
}
